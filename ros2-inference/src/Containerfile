# ── Stage 1: Python + CUDA torch + YOLO weights ───────────────────────────────
FROM docker.io/nvidia/cuda:12.6.1-cudnn-runtime-ubuntu24.04 AS python-builder
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-pip \
    python3-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*
RUN pip3 install --no-cache-dir --break-system-packages \
    opencv-python-headless \
    ultralytics \
    torch \
    torchvision \
    onnx \
    --extra-index-url https://download.pytorch.org/whl/cu126 && \
    # onnxruntime-gpu has no aarch64 wheel on PyPI — fall back to CPU build on ARM64
    ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then \
        pip3 install --no-cache-dir --break-system-packages onnxruntime-gpu; \
    else \
        pip3 install --no-cache-dir --break-system-packages onnxruntime; \
    fi
RUN mkdir -p /opt/models && \
    curl -L -o /opt/models/yolo11n.pt \
    https://github.com/ultralytics/assets/releases/download/v8.3.0/yolo11n.pt

# ── Stage 2: ROS workspace build ──────────────────────────────────────────────
FROM docker.io/library/ros:kilted-ros-base AS ros-builder
RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-kilted-cv-bridge \
    ros-kilted-vision-msgs \
    python3-colcon-common-extensions \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /ros2_ws/src/inference_node
COPY ros2_pkg/ ./
WORKDIR /ros2_ws
RUN /bin/bash -c "source /opt/ros/kilted/setup.bash && \
    colcon build --cmake-args -DCMAKE_BUILD_TYPE=Release"

# ── Stage 3: Final runtime ────────────────────────────────────────────────────
FROM docker.io/nvidia/cuda:12.6.1-cudnn-runtime-ubuntu24.04
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gnupg2 lsb-release && \
    curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
      -o /usr/share/keyrings/ros-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] \
      http://packages.ros.org/ros2/ubuntu noble main" \
      > /etc/apt/sources.list.d/ros2.list && \
    apt-get update && apt-get install -y --no-install-recommends \
    ros-kilted-ros-base \
    ros-kilted-cv-bridge \
    ros-kilted-vision-msgs \
    python3-opencv \
    python3 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*
COPY --from=python-builder /usr/local/lib/python3.12/dist-packages \
                            /usr/local/lib/python3.12/dist-packages
COPY --from=python-builder /opt/models /opt/models
COPY --from=ros-builder    /ros2_ws/install /ros2_ws/install
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
RUN mkdir -p /tmp/yolo_config/Ultralytics && chmod -R 777 /tmp/yolo_config && mkdir -p /opt/models
ENV MODELS_DIR=/opt/models
ENV YOLO_CONFIG_DIR=/tmp/yolo_config
ENV RTSP_URL=rtsp://127.0.0.1:8554/stream
ENV DETECTION_TOPIC=/detections
ENV INFERENCE_MODEL=yolo11n.pt
ENV CONFIDENCE_THRESHOLD=0.4
ENV INFERENCE_WIDTH=640
ENV INFERENCE_HEIGHT=640
ENV TARGET_FPS=30
ENV DETECTION_TTL=1.0
ENV DEVICE=auto
ENV VERBOSE=false
ENV ROS_DOMAIN_ID=0
WORKDIR /tmp
ENTRYPOINT ["/entrypoint.sh"]