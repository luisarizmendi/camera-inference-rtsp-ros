FROM ros2-fedora-base:latest

# ── RPM Fusion — required for full H264 support in ffmpeg/OpenCV ──────────────
RUN dnf install -y \
    "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm" \
    "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm" \
    && dnf -y upgrade \
    && dnf clean all

# ── Inference dependencies ────────────────────────────────────────────────────
RUN dnf install -y \
    ros-kilted-cv-bridge \
    ros-kilted-vision-msgs \
    python3-opencv \
    ffmpeg \
    ffmpeg-libs \
    && dnf clean all

# ── Python: Ultralytics YOLOv11 + CUDA-optional torch ────────────────────────
# if CUDA is available at runtime it is used automatically
# via the device auto-detection in inference_node.py.
RUN pip3 install --break-system-packages \
    ultralytics \
    torch \
    torchvision \
    --extra-index-url https://download.pytorch.org/whl/cu124

# ── Pre-download YOLO model weights during build ─────────────────────────────
# Download into /opt/yolo_models (readable by all users at runtime).
# YOLO_CONFIG_DIR points Ultralytics away from the non-writable default.
# At runtime YOLO_MODEL can be overridden; if the named file exists in
# /opt/yolo_models it is used directly without a network download.
ENV YOLO_MODELS_DIR=/opt/yolo_models
ENV YOLO_CONFIG_DIR=/tmp/yolo_config
RUN mkdir -p /tmp/yolo_config/Ultralytics && chmod -R 777 /tmp/yolo_config && mkdir -p /opt/yolo_models
RUN python3 - <<EOF
from ultralytics import YOLO
import shutil, os

m = YOLO('yolo11n.pt')
src = m.ckpt_path
shutil.copy(src, '/opt/yolo_models/yolo11n.pt')
print('Downloaded to /opt/yolo_models/yolo11n.pt')
EOF

# ── ROS2 package ──────────────────────────────────────────────────────────────
WORKDIR /ros2_ws/src/inference_node
COPY ros2_pkg/ ./

WORKDIR /ros2_ws
RUN /bin/bash -c "source /usr/lib64/ros2-kilted/setup.bash && colcon build --symlink-install"

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# ── Environment defaults ──────────────────────────────────────────────────────
ENV RTSP_URL=rtsp://127.0.0.1:8554/stream
ENV DETECTION_TOPIC=/detections
ENV YOLO_MODEL=yolo11n.pt
ENV CONFIDENCE_THRESHOLD=0.4
ENV INFERENCE_WIDTH=640
ENV INFERENCE_HEIGHT=640
ENV TARGET_FPS=30
ENV DETECTION_TTL=1.0
ENV DEVICE=auto
ENV VERBOSE=false
ENV ROS_DOMAIN_ID=0

# Use /tmp as working dir so any runtime file writes succeed
WORKDIR /tmp

ENTRYPOINT ["/entrypoint.sh"]