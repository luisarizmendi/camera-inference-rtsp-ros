<?xml version="1.0" encoding="UTF-8"?>
<!--
    FastDDS profile for containerized ROS2 services.

    By default FastDDS uses shared memory transport for localhost communication.
    Shared memory segments are NOT shared across container boundaries (separate
    mount namespaces), even when using --network host. This causes topic
    discovery to work but data to never arrive in other containers.

    This profile disables shared memory and forces UDPv4 transport, which
    works correctly across containers on the same host network.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>udp_transport</transport_id>
            <type>UDPv4</type>
        </transport_descriptor>
    </transport_descriptors>
    <participant profile_name="default_participant" is_default_profile="true">
        <rtps>
            <userTransports>
                <transport_id>udp_transport</transport_id>
            </userTransports>
            <useBuiltinTransports>false</useBuiltinTransports>
        </rtps>
    </participant>
</profiles>
