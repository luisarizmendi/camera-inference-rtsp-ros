FROM docker.io/library/ros:kilted

# ── rosbridge_suite ───────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    ros-kilted-rosbridge-server \
    ros-kilted-rosbridge-library \
    ros-kilted-rosapi \
    ros-kilted-vision-msgs \
    ros-kilted-rosidl-pycommon

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# WebSocket port
ENV ROSBRIDGE_PORT=9099
EXPOSE 9099

ENTRYPOINT ["/entrypoint.sh"]


