FROM ros2-fedora-base:latest

# All required dependencies are already in the base image

# ── ROS2 package ──────────────────────────────────────────────────────────────
WORKDIR /ros2_ws/src/image_broker
COPY ros2_pkg/ ./

WORKDIR /ros2_ws
RUN /bin/bash -c "source /usr/lib64/ros2-kilted/setup.bash && colcon build --symlink-install"

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
